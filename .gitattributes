# Normalize line endings to LF on commit, convert to OS default on checkout
* text=auto

# Force LF for source and config files
*.java text eol=lf
*.xml  text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.properties text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.sh   text eol=lf
*.csv  text eol=lf
*.py   text eol=lf

# Binary files — no line ending conversion
*.class binary
*.jar   binary
*.war   binary

# Copy to .env and fill in real values for production.
# All secrets must be >= 32 characters for HMAC-256.
APP_JWT_SECRET_MASTER=replace-with-strong-random-secret-min-32-chars
APP_JWT_SECRET_SESSION=replace-with-strong-random-secret-min-32-chars
APP_CORS_ALLOWED_ORIGINS=https://yourfrontend.com
MS_PRACTICA_URL=https://practica-service.internal
H2_CONSOLE_ENABLED=false
